<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Gradiente diagonal: noche urbana azul oscuro a violeta -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="#0A0E27"
                android:centerColor="#1B1F3A"
                android:endColor="#2D1B5C"
                android:type="linear" />
        </shape>
    </item>
    <!-- Skyline silueta inferior: 3 edificios sutiles -->
    <item android:left="20dp" android:right="20dp" android:bottom="20dp" android:top="48dp">
        <shape android:shape="rectangle">
            <solid android:color="#00000000" />
        </shape>
    </item>
</layer-list>
